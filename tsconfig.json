{
  "compilerOptions": {
    "target": "ESNext",
    "lib": ["dom", "esnext"],
    "allowSyntheticDefaultImports": true,
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "forceConsistentCasingInFileNames": true,
    "esModuleInterop": true,
    "module": "commonjs",
    "moduleResolution": "node",
    "resolveJsonModule": true,
    "jsx": "react-jsx",
    "incremental": true,
    "isolatedModules": false,
    "baseUrl": "./",
    "paths": {
      "mfe-app-one/*": ["./@types/mfe-app-one/*"],
      "mfe-app-two/*": ["./@types/mfe-app-two/*"]
    },
    "types": ["node"]
  },
  "exclude": [
    "__mocks__",
    "node_modules",
    "build",
    "dist",
    "coverage",
    "ci-scripts"
  ],
  "include": [
    "build-utils/**/*.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    "src/**/*.js",
    "src/**/*.jsx",
    "eslint.config.mjs",
    "webpack.config.ts",
    "babel.config.js",
    "release.config.js",
    "jest.setup.js"
  ]
}
